@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Re-find dependencies that were used when building the library
if(@KT_TRANSPORT_STLINK@)
    find_dependency(PkgConfig)
    if(PkgConfig_FOUND)
        pkg_check_modules(LIBUSB REQUIRED IMPORTED_TARGET libusb-1.0)
    endif()
endif()

include("${CMAKE_CURRENT_LIST_DIR}/kt_swd_progTargets.cmake")

check_required_components(kt_swd_prog)
